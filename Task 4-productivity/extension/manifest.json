{
  "name": "Time Tracker + Productivity",
  "version": "1.0.0",
  "manifest_version": 3,
  "permissions": ["tabs", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Time Tracker"
  },
  "background": {
    "service_worker": "background.js"
  }
}
